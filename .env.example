# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ──────────────────────────────────────────────
# OpenRouter (AI)
# ──────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ──────────────────────────────────────────────
# Meta WhatsApp Business API
# Per-gym credentials live in the gyms table.
# Only the app secret goes here (for signature verification).
# ──────────────────────────────────────────────
WHATSAPP_APP_SECRET=your-meta-app-secret-here

# ──────────────────────────────────────────────
# Cron job protection
# Generate with: openssl rand -hex 32
# ──────────────────────────────────────────────
CRON_SECRET=your-random-secret-here

# ──────────────────────────────────────────────
# App URL (used in OpenRouter HTTP-Referer header)
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://gymlead.ai
